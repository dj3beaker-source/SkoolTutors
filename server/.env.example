# ── Skool Tutors demo — copy to .env and fill in. NEVER commit the real .env. ──

# Demo gate: visitors must enter this code to use the live tutor + parent agent.
# Matching is case-insensitive and whitespace-tolerant. Pick something brandable +
# a few random digits so it's easy to share but not guessable (e.g. skool-pilot-2026,
# skooltutors-demo-4821). Leave blank ONLY for local testing — set it before going public.
DEMO_CODE=skool-pilot-2026

# Claude (the two-way verbal tutor brain). Same key path as HomeSkool.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ElevenLabs (tutor voice out). Same key as HomeSkool.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_VOICE_SARAH=EXAVITQu4vr4xnSDxMaL

# Demo-request emails + CRM are handled by HomeSkool's backend (it already has SMTP + a
# database). The "request a demo" form posts to homeskooltutor.com/request-demo — so set
# DEMO_CODE + SMTP/DATABASE on the HomeSkool service, not here.

# Host
PORT=4243
APP_URL=https://skooltutors.com
